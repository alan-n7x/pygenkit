[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project.name }}"
version = "{{ project.version }}"
description = "{{ project.description }}"
readme = "README.md"
requires-python = ">=3.12"
license = "MIT"
authors = [
    { name = "{{ author.name }}", email = "{{ author.email }}" },
]

dependencies = [
    "typer>=0.12",
]

[project.urls]
Repository = "https://github.com/{{ github.owner }}/{{ project.name }}"
Issues = "https://github.com/{{ github.owner }}/{{ project.name }}/issues"

[project.scripts]
{{ module_name }} = "{{ module_name }}.cli:main"

[tool.setuptools]
package-dir = { "" = "src" }

[tool.setuptools.packages.find]
where = ["src"]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "W", "I", "N", "UP", "B", "SIM", "ARG"]

[tool.ruff.format]
quote-style = "double"

[tool.mypy]
python_version = "3.12"
strict = true
ignore_missing_imports = true
exclude = ["tests/"]

[tool.pytest.ini_options]
minversion = "8.0"
testpaths = ["tests"]
