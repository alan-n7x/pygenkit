.PHONY: install lint typecheck test build clean release

install:
	uv venv && uv sync

lint:
	ruff check src/ tests/

lint-fix:
	ruff check --fix src/ tests/

typecheck:
	mypy src/

test:
	pytest

test-cov:
	pytest --cov=src/{{ module_name }} --cov-report=term-missing

build:
	pygenkit build

clean:
	rm -rf build/ dist/ *.egg-info/ .pytest_cache/ .mypy_cache/ .ruff_cache/
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true

release:
	pygenkit release

.PHONY: install lint lint-fix typecheck test test-cov build clean release
