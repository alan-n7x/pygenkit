[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project.name }}"
version = "{{ project.version }}"
description = "{{ description | default('Generated by PyGenKit') }}"
readme = "README.md"
requires-python = ">={{ python.minimum }}"
license = "{{ license }}"
authors = [
    { name = "{{ author.name }}", email = "{{ author.email }}" },
]

dependencies = []

[project.urls]
Homepage = "{{ github_url }}"
Repository = "{{ github_url }}"
Issues = "{{ github_url }}/issues"

[project.scripts]
{{ module_name }} = "{{ module_name }}.cli:main"

[tool.setuptools]
package-dir = { "" = "src" }

[tool.setuptools.packages.find]
where = ["src"]
exclude = ["tests*"]

[tool.ruff]
target-version = "py{{ python.minimum | replace('.', '') }}"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "W", "I", "N", "UP", "B", "SIM", "ARG"]

[tool.ruff.format]
quote-style = "double"

[tool.mypy]
python_version = "{{ python.minimum }}"
strict = true
ignore_missing_imports = true
exclude = ["tests/"]

[tool.pytest.ini_options]
minversion = "8.0"
testpaths = ["tests"]
python_files = ["test_*.py"]
addopts = "-v --tb=short -ra"
