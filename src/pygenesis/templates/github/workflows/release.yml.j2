name: Release

on:
  push:
    tags: ["{{ release.tag_prefix }}*"]

permissions:
  contents: write

jobs:
  release:
    runs-on: {{ ci.runner }}
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0
      - uses: actions/setup-python@v6
        with:
          python-version: "{{ ci.python_versions[0] }}"
      - name: Build
        run: |
          pip install build
          python -m build
      - name: Create Release
        uses: softprops/action-gh-release@v2
        with:
          generate_release_notes: true
          files: dist/*
